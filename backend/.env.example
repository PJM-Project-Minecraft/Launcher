APP_ENV=development
SERVER_ADDR=127.0.0.1:8080

# Доверенные прокси для X-Forwarded-For (список IP/CIDR через запятую).
# Реальный IP клиента (в т.ч. ключ брутфорс-лимитера) берётся из XFF только если
# непосредственный peer входит в этот список. Пусто — дефолт Loopback/Private.
# В production укажите точный IP/подсеть апстрим-прокси (Reverse Proxy хостинга),
# иначе возможен спуфинг X-Forwarded-For и обход лимитера. Пример:
# TRUSTED_PROXIES=192.168.88.1,10.0.0.0/8
TRUSTED_PROXIES=

# Источник аутентификации:
#   local — логин/пароль/2FA проверяются в общей БД (bcrypt + TOTP). Регистрация — через Telegram-бот.
#   http  — внешний GML-провайдер по AUTH_PROVIDER_URL (обратная совместимость).
AUTH_MODE=local
AUTH_PROVIDER_URL=https://pjm.likonchik.xyz/api/gml/auth

JWT_SECRET=change-me-in-production
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000
ADMIN_LOGINS=
PROFILE_STORAGE_ROOT=storage/profiles
PUBLIC_BASE_URL=http://127.0.0.1:8080
YGGDRASIL_KEY_PATH=data/yggdrasil_key.pem
YGGDRASIL_SERVER_NAME=Project Minecraft
AUTHLIB_INJECTOR_PATH=data/authlib-injector.jar

# Optional. If empty, backend uses local SQLite at backend/data/launcher.db.
# For PostgreSQL:
# DATABASE_URL=postgres://launcher:launcher_dev_password@127.0.0.1:5432/launcher?sslmode=disable
DATABASE_URL=

# ─── Telegram-бот (cmd/bot) ──────────────────────────────────────────────────
# Бот делит ту же БД (DATABASE_URL/SQLITE), поэтому здесь только его настройки.
TELEGRAM_BOT_TOKEN=
# Telegram id администраторов через запятую; пусто — доступ всем с ролью admin/moderator.
ADMIN_TELEGRAM_IDS=
# Подпись в приложении-аутентификаторе (TOTP issuer).
TOTP_ISSUER=Launcher Accounts
# Ссылка «Донат / магазин».
DONATE_SHOP_URL=https://shop.likonchik.xyz
# Путь к .exe лаунчера на сервере бота (для кнопки «Скачать лаунчер»). Пусто — кнопки нет.
LAUNCHER_EXE_PATH=
# Публичная прямая ссылка на скачивание (иначе строится из PUBLIC_BASE_URL).
LAUNCHER_DOWNLOAD_URL=
# Брендинг бота.
BOT_PUBLIC_NAME=Launcher Accounts
BOT_BRAND_LINE=Учётные записи игроков.
# Опционально: общий секрет заголовка x-gml-auth-secret для внешних GML-клиентов.
GML_AUTH_SECRET=
# Опционально: интеграция vps-ops-bot.
VPS_OPS_HEALTH_URL=
VPS_OPS_ALERT_STATE_PATH=
